{
  "name": "dnd-discord-bot",
  "version": "1.0.0",
  "description": "A D&D voice-notes Discord bot that joins voice channels, transcribes speech via OpenAI Whisper, and generates lore-style campaign notes with GPT.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": "Sal Vargas",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/bot.js",
    "register-commands": "node scripts/register-commands.js",
    "register-commands:guild": "node scripts/register-commands.js --guild"
  },
  "dependencies": {
    "@discordjs/voice": "^0.18.0",
    "discord.js": "^14.18.0",
    "dotenv": "^16.5.0",
    "openai": "^4.104.0",
    "opusscript": "^0.0.8",
    "prism-media": "^1.3.5",
    "tweetnacl": "^1.0.3"
  },
  "optionalDependencies": {
    "@discordjs/opus": "^0.10.0"
  }
}